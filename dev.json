{
  "$schema": "https://dev.dawson.gg/schemas/dev.v1.json",
  "name": "waypoint-guest-app",
  "slug": "wayguest",
  "services": ["web", "api"],
  "serviceAliases": {
    "api": {
      "url": ["PUBLIC_API_URL"]
    }
  },
  "session": {
    "name": "wayguest",
    "selectWindow": 0,
    "windows": [
      {
        "name": "main",
        "layout": "left-stack-right",
        "panes": [
          {
            "name": "internal",
            "command": "bun run dev:internal",
            "position": "bottom"
          },
          {
            "name": "api",
            "command": "bun run dev:api",
            "position": "main",
            "services": ["api"]
          },
          {
            "name": "web",
            "command": "bun run dev:web",
            "position": "right",
            "services": ["web"]
          }
        ]
      }
    ]
  },
  "hooks": {
    "beforeUp": [
      {
        "where": "workspace",
        "command": "bun install"
      }
    ]
  }
}
