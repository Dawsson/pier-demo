{
  "$schema": "https://dev.dawson.gg/schemas/dev.v1.json",
  "name": "pier-demo",
  "slug": "pierdemo",
  "services": ["web", "admin", "api"],
  "session": {
    "name": "pierdemo",
    "selectWindow": 0,
    "windows": [
      {
        "name": "main",
        "layout": "left-stack-right",
        "panes": [
          {
            "name": "api",
            "command": "bun run dev:api",
            "position": "main",
            "services": ["api"]
          },
          {
            "name": "web",
            "command": "bun run dev:web",
            "position": "right",
            "services": ["web"]
          },
          {
            "name": "admin",
            "command": "bun run dev:admin",
            "position": "bottom",
            "services": ["admin"]
          }
        ]
      },
      {
        "name": "daemon",
        "panes": [
          {
            "name": "daemon",
            "command": "bun run dev:daemon",
            "position": "main"
          }
        ]
      }
    ]
  }
}
