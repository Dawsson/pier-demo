{
  "name": "pier-demo",
  "private": true,
  "description": "Example app showing the ideal Pier project shape with TanStack Start, Cloudflare Workers, Better Auth, Postgres, and typed API contracts.",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run format:check && bun run check-types && bun run test",
    "check-types": "bun run --filter='@pier-demo/*' check-types",
    "deploy": "pier deploy all --env prod",
    "dev": "dev up --cwd .",
    "dev:api": "pier dev api",
    "dev:admin": "pier dev admin",
    "dev:daemon": "pier daemon start",
    "dev:web": "pier dev web",
    "doctor": "pier doctor",
    "env:types": "pier env types",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "inspect": "pier inspect --json",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "logs": "pier logs --project pier-demo",
    "plan": "pier plan",
    "submit": "pier submit",
    "test": "bun test"
  },
  "dependencies": {
    "@pier/auth": "0.1.18",
    "@pier/backend": "0.1.18",
    "@pier/core": "0.1.18",
    "@pier/db": "0.1.20",
    "@pier/log": "0.1.18",
    "better-auth": "1.6.11",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@better-auth/core": "1.6.11",
    "@better-auth/utils": "0.4.0",
    "@pier/core": "0.1.18",
    "kysely": "0.28.17"
  },
  "packageManager": "bun@1.3.12"
}
