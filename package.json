{
  "name": "pier-demo",
  "private": true,
  "description": "Example app showing the ideal Pier project shape with TanStack Start, Cloudflare Workers, Better Auth, Postgres, and typed API contracts.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run lint:patterns && bun run lint:size && bun run format:check && bun run check-types && bun run test",
    "check-types": "bun run --filter='@pier-demo/*' --filter='@repo/*' check-types",
    "deploy": "pier deploy all --env prod",
    "dev": "dev up --cwd .",
    "dev:api": "pier dev api",
    "dev:admin": "pier dev admin",
    "dev:web": "pier dev web",
    "doctor": "pier doctor",
    "env:types": "pier env types",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "inspect": "pier inspect --json",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:patterns": "ast-grep scan --report-style short",
    "lint:size": "bun tools/policies/check-file-length.ts --max 300",
    "logs": "pier logs --project pier-demo",
    "plan": "pier plan",
    "submit": "pier submit",
    "test": "bun test",
    "zero:down": "bun scripts/zero.ts down",
    "zero:logs": "bun scripts/zero.ts logs",
    "zero:permissions": "bun scripts/zero.ts permissions",
    "zero:reset": "bun scripts/zero.ts reset",
    "zero:bootstrap": "bun scripts/bootstrap-db.ts",
    "zero:up": "bun scripts/zero.ts up"
  },
  "dependencies": {
    "@pier-demo/api-contract": "workspace:*",
    "@pier/auth": "0.1.18",
    "@pier/backend": "0.1.20",
    "@pier/core": "0.1.24",
    "@pier/db": "0.1.23",
    "@pier/log": "0.1.18",
    "@pier/sync": "0.1.23",
    "@rocicorp/zero": "1.6.2",
    "better-auth": "1.6.11",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.4",
    "postgres": "^3.4.9",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.0",
    "@buildwithharbor/pier": "0.1.17",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "drizzle-kit": "^0.31.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0"
  },
  "overrides": {
    "@better-auth/core": "1.6.11",
    "@better-auth/utils": "0.4.0",
    "@pier/core": "0.1.24",
    "kysely": "0.28.17"
  },
  "packageManager": "bun@1.3.12",
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}
