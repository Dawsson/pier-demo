{
  "name": "waypoint-guest-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "../hosting-platform/packages/*"
  ],
  "scripts": {
    "check-types": "bun run --filter='*' check-types",
    "dev": "dev up --cwd .",
    "dev:api": "way dev api",
    "dev:internal": "way dev internal",
    "dev:web": "way dev web",
    "inspect": "way inspect platform.config.ts",
    "inspect:json": "way inspect platform.config.ts --json"
  },
  "dependencies": {
    "@waypoint/backend": "file:../hosting-platform/packages/backend",
    "@waypoint/core": "file:../hosting-platform/packages/core",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@waypoint/cli": "file:../hosting-platform/packages/cli",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.12"
}
